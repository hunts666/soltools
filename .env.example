# Required: a Solana JSON-RPC endpoint.
# Public api.mainnet-beta.solana.com rate-limits getTokenAccountsByOwner,
# which scan/watch rely on. Use Helius, Triton, QuickNode, or your own RPC.
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Optional alternative variable name (read if HELIUS_RPC_URL is unset).
# SOLANA_RPC_URL=https://your-other-endpoint
