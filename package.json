{
  "name": "soltools",
  "version": "0.1.0",
  "description": "Solana yield CLI — scan wallets, build staking/lending transactions, and watch for rebalance opportunities. Built on the ZXY Protocol SDK.",
  "bin": {
    "soltools": "./bin/soltools.js"
  },
  "main": "dist/cli.js",
  "files": [
    "bin",
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node bin/soltools.js",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "solana",
    "cli",
    "defi",
    "staking",
    "yield",
    "kamino",
    "jito",
    "helius"
  ],
  "license": "MIT",
  "author": "hunts666",
  "repository": {
    "type": "git",
    "url": "https://github.com/hunts666/soltools.git"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "@zxy-protocol/sdk": "file:../ZXY-Protocol-SDK",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18"
  }
}
